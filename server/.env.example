# ==========================================
# KONFIGURASI MYSQL
# Salin file ini menjadi .env lalu isi sesuai konfigurasi lokal kamu
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=ISI_PASSWORD_DB_KAMU_DI_SINI
DB_NAME=booking_rapat
DB_PORT=3306

# JWT Secret Key — ganti dengan string random yang panjang
JWT_SECRET=ganti-dengan-string-random-yang-panjang-dan-aman

# ==========================================
# DATABASE_URL (untuk Prisma, jika dipakai)
# ==========================================
DATABASE_URL=mysql://root:ISI_PASSWORD_DB_KAMU_DI_SINI@localhost:3306/booking_rapat
